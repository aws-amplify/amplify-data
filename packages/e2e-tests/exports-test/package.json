  "private": true,
  "type": "module",
  "scripts": {
    "e2e": "yarn clean && yarn install:no-lock && yarn build:esm-cjs && yarn confirm-declarations-built",
    "build:esm-cjs": "rollup -c rollup.config.mjs",
    "clean": "rm -rf yarn.lock dist",
    "install:no-lock": "yarn install",
    "confirm-declarations-built": "ls dist/esm/*.d.ts 2>/dev/null || (tput setaf 1 && echo 'declaration must be enabled in tsconfig.json for this test to be meaningful' && exit 1)"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.0.4",
    "@aws-amplify/backend-cli": "^1.1.0",
    "@aws-amplify/data-schema": "workspace:*",
    "@aws-amplify/data-schema-types": "workspace:*",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsd/typescript": "^5.5.3",
    "@types/jest": "^29.5.12",
    "@types/node": "20.8.3",
    "aws-cdk": "^2.149.0",
    "aws-cdk-lib": "^2.149.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "jest-tsd": "^0.2.2",
    "rollup": "^4.59.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
