{
  "name": "benches",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "description": "",
  "private": true,
  "main": "schema.bench.ts",
  "scripts": {
    "bench": "tsx",
    "start": "yarn bench:basic",
    "build:library": "yarn --cwd ../../ build",
    "bench:file": "yarn build:library && tsx",
    "bench:directory": "yarn build:library && ./scripts/run-benches.sh",
    "bench:basic": "yarn bench:directory basic",
    "bench:p50": "yarn bench:directory p50",
    "bench:p99": "yarn bench:directory p99",
    "bench:combine": "yarn bench:directory combine",
    "bench:all": "yarn bench:directory .",
    "baseline": "yarn build:library && ./scripts/baseline-bench.sh",
    "baseline:basic": "yarn baseline basic",
    "baseline:p50": "yarn baseline p50",
    "baseline:p99": "yarn baseline p99",
    "baseline:combine": "yarn baseline combine",
    "baseline:all": "yarn baseline .",
    "tsx": "tsx",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@arktype/attest": "^0.7.3",
    "@aws-amplify/data-schema": "*",
    "@aws-amplify/data-schema-types": "*"
  },
  "dependencies": {
    "aws-amplify": "*"
  }
}
